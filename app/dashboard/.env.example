DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=4317

# Dynatrace SaaS example: https://abc12345.live.dynatrace.com
# Dynatrace Managed/ActiveGate example: https://activegate.example.com:9999/e/ENVIRONMENT_ID
DYNATRACE_ENV_URL=
DYNATRACE_API_TOKEN=
DYNATRACE_DEFAULT_FROM=now-2h
DYNATRACE_PROBLEM_SELECTOR=status("open")
DYNATRACE_METRIC_SELECTOR=builtin:host.cpu.usage:avg:fold
DYNATRACE_INODE_METRIC_SELECTOR=builtin:host.disk.inodes.usage:avg

# Recommended current Azure OpenAI v1 endpoint style.
# Example: https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BEARER_TOKEN=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_API_STYLE=v1

# SMTP is required for sending reports by email.
# Keep credentials here instead of storing them through the dashboard UI.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REJECT_UNAUTHORIZED=true
